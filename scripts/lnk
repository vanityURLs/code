#!/usr/bin/env node

import crypto from "node:crypto";
import fs from "node:fs";
import { spawnSync } from "node:child_process";

const DEFAULT_OWNER = process.env.LNK_OWNER || "bhd";
const LINKS_FILE = resolveLinksFile();
const VALID_STATES = new Set([
  "permanent",
  "ephemeral",
  "expired",
  "disabled",
  "maintenance",
  "deactivated"
]);

function usage() {
  console.log(`LNK - create and manage VanityURLs links, schedules, and block policies.

Usage:
  ./scripts/lnk LONG_URL [SLUG]
  ./scripts/lnk --splat LONG_URL_WITH_:splat SLUG

Schedules:
  ./scripts/lnk schedule add SLUG TARGET --label LABEL --days mon,tue --from HH:MM --to HH:MM [--timezone TZ]
  ./scripts/lnk schedule default SLUG TARGET [--timezone TZ]
  ./scripts/lnk schedule list [SLUG]

Block policies:
  ./scripts/lnk block categories
  ./scripts/lnk block add DOMAIN --category CATEGORY --severity SEVERITY --reason TEXT
  ./scripts/lnk block keyword KEYWORD --category CATEGORY --severity SEVERITY --reason TEXT
  ./scripts/lnk block allow DOMAIN --reason TEXT

Options:
  --state STATE          permanent | ephemeral | expired | disabled | maintenance | deactivated
  --title TEXT           Human-readable title
  --description TEXT     Human-readable description
  --tags TAGS            Comma-separated tags
  --owner OWNER          Owner/accountability label
  --expires-at DATE      ISO date or timestamp
  --notes TEXT           Internal notes
  --splat                Create a splat link; SLUG is stored as SLUG/* in the links file
  --help                 Show this help

Files:
  Links are written to custom/v8s-links.txt when it exists, otherwise defaults/v8s-links.txt.
  Schedules are written to custom/v8s-schedules.json.
  Block policies are written to custom/v8s-policies.json.

Environment:
  DRY_RUN=true           Print the planned change without writing, committing, or pushing
  LNK_OWNER=OWNER        Default owner value for new links
  V8S_LINKS_FILE=FILE    Override the links file; LNK_FILE is supported as a legacy alias
  V8S_SCHEDULES_FILE=FILE
                         Override the schedule file
  V8S_POLICY_FILE=FILE   Override the block policy file; BLOCKLIST_FILE is a legacy alias

Notes:
  Slugs may contain / to create API-like paths.
  Successful write operations commit and push automatically.

Examples:
  ./scripts/lnk https://github.com/vanityURLs github
  ./scripts/lnk https://x.com/vanityURLs social/x
  ./scripts/lnk https://www.linkedin.com/company/example social/linkedin
  ./scripts/lnk --splat https://docs.example.com/:splat docs
  ./scripts/lnk --state ephemeral --title "Launch" https://example.com campaign/launch
  ./scripts/lnk schedule add hangout https://zoom.us/j/work --label work --days mon,tue,wed,thu,fri --from 09:00 --to 17:00 --timezone America/Toronto
  ./scripts/lnk schedule default hangout https://discord.gg/personal

Docs:
  https://www.VanityURLs.link/en/docs`);
}

function resolveLinksFile() {
  if (process.env.V8S_LINKS_FILE) return process.env.V8S_LINKS_FILE;
  if (process.env.LNK_FILE) return process.env.LNK_FILE;
  if (fs.existsSync("custom/v8s-links.txt")) return "custom/v8s-links.txt";
  return "defaults/v8s-links.txt";
}

function run(command, args) {
  const result = spawnSync(command, args, {
    cwd: process.cwd(),
    stdio: "inherit",
    shell: process.platform === "win32"
  });

  if (result.error) {
    throw result.error;
  }

  if (result.status !== 0) {
    process.exit(result.status ?? 1);
  }
}

function parseArgs(argv) {
  const options = {
    state: "permanent",
    splat: false,
    title: "",
    description: "",
    tags: "",
    owner: DEFAULT_OWNER,
    expiresAt: "",
    notes: ""
  };
  const positionals = [];

  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];

    if (arg === "--help" || arg === "-h") {
      options.help = true;
    } else if (arg === "--splat") {
      options.splat = true;
    } else if (arg === "--state") {
      options.state = readOptionValue(argv, index, arg);
      index += 1;
    } else if (arg === "--title") {
      options.title = readOptionValue(argv, index, arg);
      index += 1;
    } else if (arg === "--description") {
      options.description = readOptionValue(argv, index, arg);
      index += 1;
    } else if (arg === "--tags") {
      options.tags = readOptionValue(argv, index, arg);
      index += 1;
    } else if (arg === "--owner") {
      options.owner = readOptionValue(argv, index, arg);
      index += 1;
    } else if (arg === "--expires-at") {
      options.expiresAt = readOptionValue(argv, index, arg);
      index += 1;
    } else if (arg === "--notes") {
      options.notes = readOptionValue(argv, index, arg);
      index += 1;
    } else if (arg.startsWith("--")) {
      throw new Error(`Unknown option: ${arg}`);
    } else {
      positionals.push(arg);
    }
  }

  return {
    options,
    positionals
  };
}

function readOptionValue(argv, index, name) {
  const value = argv[index + 1];
  if (value === undefined) {
    throw new Error(`Missing value for ${name}`);
  }
  return value;
}

function normalizeSlug(value) {
  let slug = String(value || "").trim();
  slug = slug.replace(/^\/+/, "").replace(/\/+$/, "");

  while (slug.includes("//")) {
    slug = slug.replaceAll("//", "/");
  }

  return slug;
}

function validateSlug(slug) {
  if (!slug) {
    throw new Error("Slug is required.");
  }

  if (slug.startsWith("/") || slug.endsWith("/")) {
    throw new Error("Slug must not start or end with /.");
  }

  if (slug.includes("//") || slug.includes("?") || slug.includes("#")) {
    throw new Error("Slug must not contain //, ?, or #.");
  }

  for (const part of slug.split("/")) {
    if (!/^[A-Za-z0-9][A-Za-z0-9._~-]*$/.test(part)) {
      throw new Error(`Invalid slug segment: ${part}\nUse URL-safe segments starting with a letter or digit.`);
    }
  }
}

function assertNoPipe(values) {
  if (values.some((value) => String(value).includes("|"))) {
    throw new Error("The pipe character | is reserved by the v8s links format.");
  }
}

function slugExists(filePath, slug) {
  if (!fs.existsSync(filePath)) return false;

  const rows = fs.readFileSync(filePath, "utf8").split(/\r?\n/);
  return rows.some((row) => row.split("|")[0] === slug);
}

function randomSlug() {
  return crypto.randomBytes(3).toString("hex");
}

function appendLine(filePath, line) {
  fs.mkdirSync(dirname(filePath), {
    recursive: true
  });
  fs.appendFileSync(filePath, `${line}\n`);
}

function dirname(filePath) {
  const index = Math.max(filePath.lastIndexOf("/"), filePath.lastIndexOf("\\"));
  if (index < 0) return ".";
  return filePath.slice(0, index) || ".";
}

function readJson(filePath, fallback) {
  if (!fs.existsSync(filePath)) return fallback;
  return JSON.parse(fs.readFileSync(filePath, "utf8"));
}

function writeJson(filePath, value) {
  fs.mkdirSync(dirname(filePath), {
    recursive: true
  });
  fs.writeFileSync(filePath, `${JSON.stringify(value, null, 2)}\n`);
}

function parseGenericArgs(argv) {
  const options = {};
  const positionals = [];

  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];

    if (arg === "--dry-run") {
      options.dryRun = true;
    } else if (arg === "--help" || arg === "-h") {
      options.help = true;
    } else if (arg.startsWith("--")) {
      const key = arg.slice(2).replace(/-([a-z])/g, (_, letter) => letter.toUpperCase());
      options[key] = readOptionValue(argv, index, arg);
      index += 1;
    } else {
      positionals.push(arg);
    }
  }

  return {
    options,
    positionals
  };
}

function scheduleUsage() {
  console.log(`LNK schedules - manage time-based targets.

Usage:
  ./scripts/lnk schedule add SLUG TARGET --label LABEL --days mon,tue --from HH:MM --to HH:MM [--timezone TZ]
  ./scripts/lnk schedule default SLUG TARGET [--timezone TZ]
  ./scripts/lnk schedule list [SLUG]

Options:
  --file FILE            Schedule JSON path, defaults to custom/v8s-schedules.json
  --label LABEL          Rule label shown in analytics, required for add
  --timezone TZ          IANA timezone, defaults to UTC
  --days DAYS            Comma-separated weekdays, for example mon,tue,wed,thu,fri
  --from HH:MM           Start time, inclusive
  --to HH:MM             End time, exclusive
  --default TARGET       Optional fallback target to set while adding a rule
  --dry-run              Print updated JSON without writing
  --help                 Show this help`);
}

function schedulePath(options) {
  return options.file || process.env.V8S_SCHEDULES_FILE || "custom/v8s-schedules.json";
}

function normalizeTarget(value) {
  const target = String(value || "").trim();
  if (!target) return "";
  if (/^https?:\/\//i.test(target)) return target;
  return `https://${target}`;
}

function normalizeDays(value) {
  const valid = new Set(["mon", "tue", "wed", "thu", "fri", "sat", "sun"]);
  const days = String(value || "")
    .split(",")
    .map((day) => day.trim().slice(0, 3).toLowerCase())
    .filter(Boolean);

  if (!days.length) {
    throw new Error("--days is required");
  }

  for (const day of days) {
    if (!valid.has(day)) {
      throw new Error(`Invalid day: ${day}`);
    }
  }

  return [...new Set(days)];
}

function validateTime(value, optionName) {
  if (!/^([01]\d|2[0-3]):[0-5]\d$/.test(String(value || ""))) {
    throw new Error(`${optionName} must use HH:MM`);
  }
  return value;
}

function ensureSchedule(config, slug, timezone) {
  config[slug] ||= {};
  config[slug].timezone ||= timezone || "UTC";
  config[slug].rules ||= [];
  return config[slug];
}

function saveScheduleConfig(filePath, config, dryRun, slug) {
  if (dryRun || process.env.DRY_RUN === "true") {
    console.log(JSON.stringify(config, null, 2));
    return;
  }

  writeJson(filePath, config);
  run("git", ["add", filePath]);
  run("git", ["commit", "-m", `feat(schedules): update ${slug}`]);
  run("git", ["push"]);
}

function listSchedules(config, requestedSlug) {
  const entries = Object.entries(config)
    .filter(([slug]) => !requestedSlug || slug === requestedSlug);

  if (!entries.length) {
    console.log(requestedSlug ? `No schedule found for ${requestedSlug}` : "No schedules configured");
    return;
  }

  for (const [slug, schedule] of entries) {
    console.log(slug);
    if (schedule.default) console.log(`  default -> ${schedule.default}`);
    for (const rule of schedule.rules || []) {
      console.log(`  ${rule.label}: ${rule.days.join(",")} ${rule.from}-${rule.to} ${rule.timezone} -> ${rule.target}`);
    }
  }
}

function handleSchedule(argv) {
  const subcommand = argv[0] || "";
  const { options, positionals } = parseGenericArgs(argv.slice(1));
  const filePath = schedulePath(options);
  const config = readJson(filePath, {});

  if (!subcommand || options.help || subcommand === "--help" || subcommand === "-h") {
    scheduleUsage();
    return;
  }

  if (subcommand === "list") {
    const requestedSlug = positionals[0] ? normalizeSlug(positionals[0]) : "";
    listSchedules(config, requestedSlug);
    return;
  }

  const slug = normalizeSlug(positionals[0] || "");
  const target = normalizeTarget(positionals[1] || "");
  validateSlug(slug);

  if (!target) {
    throw new Error("Target is required.");
  }

  if (subcommand === "default") {
    if (!Array.isArray(config[slug]?.rules) || config[slug].rules.length === 0) {
      throw new Error(`Schedule for ${slug} must have at least one rule before setting a default target.`);
    }

    const schedule = ensureSchedule(config, slug, options.timezone || "UTC");
    schedule.default = target;
    if (options.timezone) schedule.timezone = options.timezone;
    saveScheduleConfig(filePath, config, options.dryRun, slug);
    return;
  }

  if (subcommand === "add") {
    if (!options.label) throw new Error("--label is required");

    const timezone = options.timezone || "UTC";
    const schedule = ensureSchedule(config, slug, timezone);
    if (options.timezone) schedule.timezone = timezone;

    const rule = {
      label: options.label,
      timezone,
      days: normalizeDays(options.days),
      from: validateTime(options.from, "--from"),
      to: validateTime(options.to, "--to"),
      target
    };

    const existingIndex = schedule.rules.findIndex((item) => item.label === rule.label);
    if (existingIndex >= 0) {
      schedule.rules[existingIndex] = {
        ...schedule.rules[existingIndex],
        ...rule
      };
    } else {
      schedule.rules.push(rule);
    }

    if (options.default) {
      schedule.default = normalizeTarget(options.default);
    }

    saveScheduleConfig(filePath, config, options.dryRun, slug);
    return;
  }

  throw new Error(`Unknown schedule command: ${subcommand}`);
}

function main() {
  const argv = process.argv.slice(2);

  if (argv[0] === "block") {
    run(process.execPath, ["scripts/blocklist-cli.mjs", ...argv.slice(1)]);
    return;
  }

  if (argv[0] === "schedule") {
    handleSchedule(argv.slice(1));
    return;
  }

  const { options, positionals } = parseArgs(argv);

  if (options.help) {
    usage();
    return;
  }

  const target = positionals[0] || "";
  let slug = positionals[1] || "";

  if (!target) {
    usage();
    process.exit(1);
  }

  if (!slug) {
    slug = randomSlug();
  }

  if (options.state === "hidden") {
    throw new Error("State 'hidden' is deprecated. Use 'deactivated'.");
  }

  if (!VALID_STATES.has(options.state)) {
    throw new Error(`Invalid state: ${options.state}`);
  }

  slug = normalizeSlug(slug);
  validateSlug(slug);

  if (options.splat) {
    if (!target.includes(":splat")) {
      throw new Error("Splat target must include :splat");
    }
    slug = `${slug.replace(/\/+$/, "")}/*`;
  }

  const fields = [
    slug,
    target,
    options.state,
    options.title,
    options.description,
    options.tags,
    options.owner,
    options.expiresAt,
    options.notes
  ];
  assertNoPipe(fields);

  const line = fields.join("|");

  if (process.env.DRY_RUN === "true") {
    console.log(line);
    return;
  }

  if (slugExists(LINKS_FILE, slug)) {
    throw new Error(`Slug already exists in ${LINKS_FILE}: ${slug}`);
  }

  appendLine(LINKS_FILE, line);

  run("git", ["add", LINKS_FILE]);
  run("git", ["commit", "-m", `feat(links): add ${slug}`]);
  run("git", ["push"]);
}

try {
  main();
} catch (error) {
  console.error(error instanceof Error ? error.message : String(error));
  process.exit(1);
}
