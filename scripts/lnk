#!/usr/bin/env node

import crypto from "node:crypto";
import fs from "node:fs";
import path from "node:path";
import { fileURLToPath } from "node:url";
import { spawnSync } from "node:child_process";
import readline from "node:readline/promises";
import { stdin as input, stdout as output } from "node:process";

const ROOT = resolveRoot();
process.chdir(ROOT);

const VERSION = readPackageVersion();
const DEFAULT_OWNER = process.env.V8S_LINKS_OWNER || "bhd";
const LINKS_FILE = resolveLinksFile();
const DEFAULT_SITE_CONFIG_FILE = "defaults/v8s-site-config.json";
const CUSTOM_SITE_CONFIG_FILE = "custom/v8s-site-config.json";
const DEFAULT_RANDOM_SLUG_LENGTH = 3;
const MAX_RANDOM_SLUG_LENGTH = 64;
const DEFAULT_RANDOM_SLUG_ALPHABET = "34789abcdefghjkmnpqrstvwxy";
const VALID_STATES = new Set([
  "permanent",
  "ephemeral",
  "expired",
  "disabled",
  "maintenance",
  "deactivated"
]);

function usage() {
  console.log(`LNK - create and manage VanityURLs links, schedules, and block policies.
Version: ${VERSION}

Usage:
  ./scripts/lnk LONG_URL [SLUG]
  ./scripts/lnk LONG_URL [--random-slug-length LENGTH]
  ./scripts/lnk --splat LONG_URL_WITH_:splat SLUG
  ./scripts/lnk list [SLUG]
  ./scripts/lnk list policy
  ./scripts/lnk list categories
  ./scripts/lnk list domain [block|allow]
  ./scripts/lnk list keyword
  ./scripts/lnk tag list
  ./scripts/lnk tag set TAG --random-slug-length LENGTH
  ./scripts/lnk tag unset TAG
  ./scripts/lnk version

Schedules:
  ./scripts/lnk schedule add SLUG TARGET --label LABEL --days mon,tue --from HH:MM --to HH:MM [--timezone TZ]
  ./scripts/lnk schedule default SLUG TARGET [--timezone TZ]
  ./scripts/lnk schedule list [SLUG]

Block policies:
  ./scripts/lnk block categories
  ./scripts/lnk block add DOMAIN --category CATEGORY --severity SEVERITY --reason TEXT
  ./scripts/lnk block keyword KEYWORD --category CATEGORY --severity SEVERITY --reason TEXT
  ./scripts/lnk block allow DOMAIN --reason TEXT

Options:
  --format FORMAT        table | json for list output
  --state STATE          permanent | ephemeral | expired | disabled | maintenance | deactivated
  --title TEXT           Human-readable title
  --description TEXT     Human-readable description
  --tags TAGS            Comma-separated tags
  --owner OWNER          Owner/accountability label
  --expires-at DATE      ISO date or timestamp
  --notes TEXT           Internal notes
  --random-slug-length N Character count for a generated slug
  --slug-length N        Alias for --random-slug-length
  --replace              Replace an existing slug without prompting
  --no-replace           Do not replace an existing slug
  --splat                Create a splat link; SLUG is stored as SLUG/* in the links file
  --help                 Show this help

Files:
  Links are written to custom/v8s-links.txt unless V8S_LINKS_FILE overrides the path.
  Schedules are written to custom/v8s-schedules.json.
  Block policies are written to custom/v8s-policies.json.
  Link CLI defaults are read from custom/v8s-site-config.json.

Environment:
  DRY_RUN=true           Print the planned change without writing, committing, or pushing
  V8S_REPO=PATH          Local vanityURLs/code repository path
  V8S_LINKS_OWNER=OWNER  Default owner value for new links
  V8S_LINKS_FILE=FILE    Override the links file
  V8S_SCHEDULES_FILE=FILE
                         Override the schedule file
  V8S_POLICY_FILE=FILE   Override the block policy file

Notes:
  Slugs may contain / to create API-like paths.
  Random slugs use the configured readable alphabet. The product default is ${DEFAULT_RANDOM_SLUG_ALPHABET}.
  Tag-specific random slug lengths use the shortest matching tag default.
  Successful write operations run npm run check, then commit and push automatically.

Examples:
  ./scripts/lnk list
  ./scripts/lnk list social/x
  ./scripts/lnk list domain allow
  ./scripts/lnk list keyword --format json
  ./scripts/lnk https://github.com/vanityURLs github
  ./scripts/lnk https://github.com/houba/styleGuide --random-slug-length 5
  ./scripts/lnk tag set social --random-slug-length 5
  ./scripts/lnk https://x.com/vanityURLs social/x
  ./scripts/lnk https://www.linkedin.com/company/example social/linkedin
  ./scripts/lnk --splat https://docs.example.com/:splat docs
  ./scripts/lnk --state ephemeral --title "Launch" https://example.com campaign/launch
  ./scripts/lnk schedule add hangout https://zoom.us/j/work --label work --days mon,tue,wed,thu,fri --from 09:00 --to 17:00 --timezone America/Toronto
  ./scripts/lnk schedule default hangout https://discord.gg/personal

Docs:
  https://www.VanityURLs.link/en/docs`);
}

function readPackageVersion() {
  try {
    return JSON.parse(fs.readFileSync("package.json", "utf8")).version || "0.0.0";
  } catch {
    return "0.0.0";
  }
}

function resolveRoot() {
  const scriptRoot = path.dirname(path.dirname(fileURLToPath(import.meta.url)));
  const sourceScriptPath = path.join(scriptRoot, "scripts", "lnk");
  const isRepositoryScript = fs.existsSync(path.join(scriptRoot, "package.json")) && fs.existsSync(sourceScriptPath);

  if (isRepositoryScript) return scriptRoot;

  return process.env.V8S_REPO || process.cwd();
}

function resolveLinksFile() {
  if (process.env.V8S_LINKS_FILE) return process.env.V8S_LINKS_FILE;
  return "custom/v8s-links.txt";
}

function run(command, args) {
  const result = spawnSync(command, args, {
    cwd: process.cwd(),
    stdio: "inherit",
    shell: process.platform === "win32"
  });

  if (result.error) {
    throw result.error;
  }

  if (result.status !== 0) {
    process.exit(result.status ?? 1);
  }
}

function parseArgs(argv) {
  const options = {
    format: "table",
    state: "permanent",
    splat: false,
    title: "",
    description: "",
    tags: "",
    owner: DEFAULT_OWNER,
    expiresAt: "",
    notes: "",
    randomSlugLength: ""
  };
  const positionals = [];

  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];

    if (arg === "--help" || arg === "-h") {
      options.help = true;
    } else if (arg === "--format") {
      options.format = readOptionValue(argv, index, arg);
      index += 1;
    } else if (arg === "--splat") {
      options.splat = true;
    } else if (arg === "--state") {
      options.state = readOptionValue(argv, index, arg);
      index += 1;
    } else if (arg === "--title") {
      options.title = readOptionValue(argv, index, arg);
      index += 1;
    } else if (arg === "--description") {
      options.description = readOptionValue(argv, index, arg);
      index += 1;
    } else if (arg === "--tags") {
      options.tags = readOptionValue(argv, index, arg);
      index += 1;
    } else if (arg === "--owner") {
      options.owner = readOptionValue(argv, index, arg);
      index += 1;
    } else if (arg === "--expires-at") {
      options.expiresAt = readOptionValue(argv, index, arg);
      index += 1;
    } else if (arg === "--notes") {
      options.notes = readOptionValue(argv, index, arg);
      index += 1;
    } else if (arg === "--random-slug-length" || arg === "--slug-length") {
      options.randomSlugLength = readOptionValue(argv, index, arg);
      index += 1;
    } else if (arg === "--replace") {
      options.replace = true;
    } else if (arg === "--no-replace") {
      options.replace = false;
    } else if (arg.startsWith("--")) {
      throw new Error(`Unknown option: ${arg}`);
    } else {
      positionals.push(arg);
    }
  }

  return {
    options,
    positionals
  };
}

function readOptionValue(argv, index, name) {
  const value = argv[index + 1];
  if (value === undefined) {
    throw new Error(`Missing value for ${name}`);
  }
  return value;
}

function normalizeSlug(value) {
  let slug = String(value || "").trim();
  slug = slug.replace(/^\/+/, "").replace(/\/+$/, "");

  while (slug.includes("//")) {
    slug = slug.replaceAll("//", "/");
  }

  return slug;
}

function validateSlug(slug) {
  if (!slug) {
    throw new Error("Slug is required.");
  }

  if (slug.startsWith("/") || slug.endsWith("/")) {
    throw new Error("Slug must not start or end with /.");
  }

  if (slug.includes("//") || slug.includes("?") || slug.includes("#")) {
    throw new Error("Slug must not contain //, ?, or #.");
  }

  for (const part of slug.split("/")) {
    if (!/^[A-Za-z0-9][A-Za-z0-9._~-]*$/.test(part)) {
      throw new Error(`Invalid slug segment: ${part}\nUse URL-safe segments starting with a letter or digit.`);
    }
  }
}

function assertNoPipe(values) {
  if (values.some((value) => String(value).includes("|"))) {
    throw new Error("The pipe character | is reserved by the v8s links format.");
  }
}

function findSlugEntry(filePath, slug) {
  if (!fs.existsSync(filePath)) return null;

  const rows = fs.readFileSync(filePath, "utf8").split(/\r?\n/);
  for (let index = 0; index < rows.length; index += 1) {
    const row = rows[index];
    if (!row.trim() || row.trim().startsWith("#")) continue;
    if (row.split("|")[0] === slug) {
      return {
        index,
        line: row,
        fields: parseLinkFields(row)
      };
    }
  }

  return null;
}

function parseLinkFields(line) {
  const [
    slug = "",
    target = "",
    state = "",
    title = "",
    description = "",
    tags = "",
    owner = "",
    expiresAt = "",
    notes = ""
  ] = String(line || "").split("|");

  return {
    slug,
    target,
    state,
    title,
    description,
    tags,
    owner,
    expiresAt,
    notes
  };
}

function replaceLine(filePath, index, line) {
  const existing = fs.readFileSync(filePath, "utf8");
  const hasTrailingNewline = existing.endsWith("\n");
  const rows = existing.split(/\r?\n/);
  rows[index] = line;
  fs.writeFileSync(filePath, `${rows.join("\n").replace(/\n*$/g, "")}${hasTrailingNewline ? "\n" : ""}`);
}

function randomSlug(length, alphabet) {
  const size = normalizeRandomSlugLength(length, "random slug length");
  const characters = normalizeRandomSlugAlphabet(alphabet);
  let slug = "";
  for (let index = 0; index < size; index += 1) {
    slug += characters[crypto.randomInt(characters.length)];
  }
  return slug;
}

function normalizeRandomSlugLength(value, label = "random slug length") {
  const number = Number.parseInt(String(value || ""), 10);
  if (!Number.isInteger(number) || number < 1 || number > MAX_RANDOM_SLUG_LENGTH) {
    throw new Error(`${label} must be an integer from 1 to ${MAX_RANDOM_SLUG_LENGTH}.`);
  }
  return number;
}

function normalizeRandomSlugAlphabet(value) {
  const alphabet = String(value || DEFAULT_RANDOM_SLUG_ALPHABET).trim();
  if (!alphabet) {
    throw new Error("random_slug_alphabet cannot be empty.");
  }

  const unique = [...new Set([...alphabet])].join("");
  if (unique !== alphabet) {
    throw new Error("random_slug_alphabet must not contain duplicate characters.");
  }

  for (const character of alphabet) {
    if (!/^[A-Za-z0-9._~-]$/.test(character)) {
      throw new Error(`Invalid random_slug_alphabet character: ${character}`);
    }
  }

  return alphabet;
}

function normalizeTag(value) {
  const tag = String(value || "").trim().toLowerCase();
  if (!/^[a-z0-9][a-z0-9._~-]*$/.test(tag)) {
    throw new Error(`Invalid tag: ${value}\nUse lowercase URL-safe tags starting with a letter or digit.`);
  }
  return tag;
}

function normalizeTags(value) {
  return String(value || "")
    .split(",")
    .map((tag) => tag.trim())
    .filter(Boolean)
    .map(normalizeTag);
}

function mergeSiteConfig(base, custom) {
  return {
    ...base,
    ...custom,
    links: {
      ...(base.links || {}),
      ...(custom.links || {}),
      tag_random_slug_lengths: {
        ...(base.links?.tag_random_slug_lengths || {}),
        ...(custom.links?.tag_random_slug_lengths || {})
      }
    }
  };
}

function readSiteConfig() {
  return mergeSiteConfig(
    readJson(DEFAULT_SITE_CONFIG_FILE, {}),
    readJson(CUSTOM_SITE_CONFIG_FILE, {})
  );
}

function readCustomSiteConfig() {
  return readJson(CUSTOM_SITE_CONFIG_FILE, {});
}

function writeCustomSiteConfig(config) {
  writeJson(CUSTOM_SITE_CONFIG_FILE, config);
}

function configuredRandomSlugLength(options) {
  if (options.randomSlugLength) {
    return normalizeRandomSlugLength(options.randomSlugLength, "--random-slug-length");
  }

  const siteConfig = readSiteConfig();
  const globalLength = normalizeRandomSlugLength(
    siteConfig.links?.random_slug_length || DEFAULT_RANDOM_SLUG_LENGTH
  );
  const tagLengths = siteConfig.links?.tag_random_slug_lengths || {};
  const matchingLengths = normalizeTags(options.tags)
    .map((tag) => tagLengths[tag])
    .filter((value) => value !== undefined && value !== "")
    .map((value) => normalizeRandomSlugLength(value, "tag random slug length"));

  return matchingLengths.length ? Math.min(...matchingLengths) : globalLength;
}

function configuredRandomSlugAlphabet() {
  const siteConfig = readSiteConfig();
  return normalizeRandomSlugAlphabet(siteConfig.links?.random_slug_alphabet || DEFAULT_RANDOM_SLUG_ALPHABET);
}

function appendLine(filePath, line) {
  fs.mkdirSync(dirname(filePath), {
    recursive: true
  });

  if (!fs.existsSync(filePath)) {
    fs.writeFileSync(filePath, "# slug|target|state|title|description|tags|owner|expires_at|notes\n");
  }

  fs.appendFileSync(filePath, `${line}\n`);
}

function dirname(filePath) {
  const index = Math.max(filePath.lastIndexOf("/"), filePath.lastIndexOf("\\"));
  if (index < 0) return ".";
  return filePath.slice(0, index) || ".";
}

function readJson(filePath, fallback) {
  if (!fs.existsSync(filePath)) return fallback;
  return JSON.parse(fs.readFileSync(filePath, "utf8"));
}

function ensureRegistry() {
  const registryPath = "build/v8s.json";
  if (!fs.existsSync(registryPath)) {
    run("npm", ["run", "build"]);
  }

  return readJson(registryPath, { links: [] });
}

function listLinks(requestedSlug, options) {
  const registry = ensureRegistry();
  const slug = requestedSlug ? normalizeSlug(requestedSlug) : "";
  const links = (registry.links || [])
    .filter((link) => !slug || link.slug === slug)
    .sort((a, b) => a.slug.localeCompare(b.slug));

  if (options.format === "json") {
    console.log(JSON.stringify(links, null, 2));
    return;
  }

  if (options.format !== "table") {
    throw new Error("--format must be table or json");
  }

  if (!links.length) {
    console.log(slug ? `No link found for ${slug}` : "No links configured");
    return;
  }

  printTable(links.map((link) => {
    return [
      link.slug,
      link.state || "permanent",
      link.owner || "",
      link.title || "",
      link.target || ""
    ];
  }), ["Slug", "State", "Owner", "Title", "Target"]);
}

function printTable(rows, headers) {
  const widths = headers.map((header, index) => {
    return Math.min(40, Math.max(header.length, ...rows.map((row) => String(row[index] || "").length)));
  });

  console.log(headers.map((header, index) => padCell(header, widths[index])).join("  "));
  console.log(widths.map((width) => "-".repeat(width)).join("  "));

  for (const row of rows) {
    console.log(row.map((cell, index) => padCell(truncateCell(cell, widths[index]), widths[index])).join("  "));
  }
}

function truncateCell(value, width) {
  const text = String(value || "");
  if (text.length <= width) return text;
  return `${text.slice(0, Math.max(0, width - 1))}…`;
}

function padCell(value, width) {
  return String(value || "").padEnd(width, " ");
}

function writeJson(filePath, value) {
  fs.mkdirSync(dirname(filePath), {
    recursive: true
  });
  fs.writeFileSync(filePath, `${JSON.stringify(value, null, 2)}\n`);
}

function parseGenericArgs(argv) {
  const options = {};
  const positionals = [];

  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];

    if (arg === "--dry-run") {
      options.dryRun = true;
    } else if (arg === "--help" || arg === "-h") {
      options.help = true;
    } else if (arg.startsWith("--")) {
      const key = arg.slice(2).replace(/-([a-z])/g, (_, letter) => letter.toUpperCase());
      options[key] = readOptionValue(argv, index, arg);
      index += 1;
    } else {
      positionals.push(arg);
    }
  }

  return {
    options,
    positionals
  };
}

function tagUsage() {
  console.log(`LNK tags - manage tag-specific random slug defaults.

Usage:
  ./scripts/lnk tag list
  ./scripts/lnk tag set TAG --random-slug-length LENGTH
  ./scripts/lnk tag unset TAG

Options:
  --format FORMAT        table | json for list output
  --random-slug-length N Character count for generated slugs using this tag
  --slug-length N        Alias for --random-slug-length
  --dry-run              Print updated JSON without writing
  --help                 Show this help`);
}

function tagRandomSlugLengths(config) {
  return config.links?.tag_random_slug_lengths || {};
}

function handleTags(argv) {
  const subcommand = argv[0] || "";
  const { options, positionals } = parseGenericArgs(argv.slice(1));

  if (!subcommand || options.help || subcommand === "--help" || subcommand === "-h") {
    tagUsage();
    return;
  }

  if (subcommand === "list") {
    const config = readSiteConfig();
    const globalLength = normalizeRandomSlugLength(config.links?.random_slug_length || DEFAULT_RANDOM_SLUG_LENGTH);
    const alphabet = normalizeRandomSlugAlphabet(config.links?.random_slug_alphabet || DEFAULT_RANDOM_SLUG_ALPHABET);
    const rows = Object.entries(tagRandomSlugLengths(config))
      .sort(([left], [right]) => left.localeCompare(right))
      .map(([tag, length]) => [tag, String(length)]);

    if (options.format === "json") {
      console.log(JSON.stringify({
        random_slug_length: globalLength,
        random_slug_alphabet: alphabet,
        tag_random_slug_lengths: Object.fromEntries(
          Object.entries(tagRandomSlugLengths(config))
            .sort(([left], [right]) => left.localeCompare(right))
            .map(([tag, length]) => [tag, normalizeRandomSlugLength(length, "tag random slug length")])
        )
      }, null, 2));
      return;
    }

    if (options.format && options.format !== "table") {
      throw new Error("--format must be table or json");
    }

    console.log(`Global random slug length: ${globalLength}`);
    console.log(`Random slug alphabet: ${alphabet}`);
    if (!rows.length) {
      console.log("No tag-specific random slug lengths configured");
      return;
    }
    printTable(rows, ["Tag", "Random slug length"]);
    return;
  }

  const tag = normalizeTag(positionals[0] || "");
  const customConfig = readCustomSiteConfig();
  customConfig.links ||= {};
  customConfig.links.tag_random_slug_lengths ||= {};

  if (subcommand === "set") {
    const rawLength = options.randomSlugLength || options.slugLength;
    const length = normalizeRandomSlugLength(rawLength, "--random-slug-length");
    customConfig.links.tag_random_slug_lengths[tag] = length;
    saveTagConfig(customConfig, options.dryRun, `chore(lnk): set ${tag} random slug length`);
    return;
  }

  if (subcommand === "unset") {
    delete customConfig.links.tag_random_slug_lengths[tag];
    saveTagConfig(customConfig, options.dryRun, `chore(lnk): unset ${tag} random slug length`);
    return;
  }

  throw new Error(`Unknown tag command: ${subcommand}`);
}

function saveTagConfig(config, dryRun, message) {
  if (dryRun || process.env.DRY_RUN === "true") {
    console.log(JSON.stringify(config, null, 2));
    return;
  }

  writeCustomSiteConfig(config);
  finalizeChange(CUSTOM_SITE_CONFIG_FILE, message);
}

function scheduleUsage() {
  console.log(`LNK schedules - manage time-based targets.

Usage:
  ./scripts/lnk schedule add SLUG TARGET --label LABEL --days mon,tue --from HH:MM --to HH:MM [--timezone TZ]
  ./scripts/lnk schedule default SLUG TARGET [--timezone TZ]
  ./scripts/lnk schedule list [SLUG]

Options:
  --file FILE            Schedule JSON path, defaults to custom/v8s-schedules.json
  --label LABEL          Rule label shown in analytics, required for add
  --timezone TZ          IANA timezone, defaults to UTC
  --days DAYS            Comma-separated weekdays, for example mon,tue,wed,thu,fri
  --from HH:MM           Start time, inclusive
  --to HH:MM             End time, exclusive
  --default TARGET       Optional fallback target to set while adding a rule
  --dry-run              Print updated JSON without writing
  --help                 Show this help`);
}

function schedulePath(options) {
  return options.file || process.env.V8S_SCHEDULES_FILE || "custom/v8s-schedules.json";
}

function normalizeTarget(value) {
  const target = String(value || "").trim();
  if (!target) return "";
  if (/^https?:\/\//i.test(target)) return target;
  return `https://${target}`;
}

function normalizeDays(value) {
  const valid = new Set(["mon", "tue", "wed", "thu", "fri", "sat", "sun"]);
  const days = String(value || "")
    .split(",")
    .map((day) => day.trim().slice(0, 3).toLowerCase())
    .filter(Boolean);

  if (!days.length) {
    throw new Error("--days is required");
  }

  for (const day of days) {
    if (!valid.has(day)) {
      throw new Error(`Invalid day: ${day}`);
    }
  }

  return [...new Set(days)];
}

function validateTime(value, optionName) {
  if (!/^([01]\d|2[0-3]):[0-5]\d$/.test(String(value || ""))) {
    throw new Error(`${optionName} must use HH:MM`);
  }
  return value;
}

function ensureSchedule(config, slug, timezone) {
  config[slug] ||= {};
  config[slug].timezone ||= timezone || "UTC";
  config[slug].rules ||= [];
  return config[slug];
}

function saveScheduleConfig(filePath, config, dryRun, slug) {
  if (dryRun || process.env.DRY_RUN === "true") {
    console.log(JSON.stringify(config, null, 2));
    return;
  }

  writeJson(filePath, config);
  finalizeChange(filePath, `feat(schedules): update ${slug}`);
}

function listSchedules(config, requestedSlug) {
  const entries = Object.entries(config)
    .filter(([slug]) => !requestedSlug || slug === requestedSlug);

  if (!entries.length) {
    console.log(requestedSlug ? `No schedule found for ${requestedSlug}` : "No schedules configured");
    return;
  }

  for (const [slug, schedule] of entries) {
    console.log(slug);
    if (schedule.default) console.log(`  default -> ${schedule.default}`);
    for (const rule of schedule.rules || []) {
      console.log(`  ${rule.label}: ${rule.days.join(",")} ${rule.from}-${rule.to} ${rule.timezone} -> ${rule.target}`);
    }
  }
}

function handleSchedule(argv) {
  const subcommand = argv[0] || "";
  const { options, positionals } = parseGenericArgs(argv.slice(1));
  const filePath = schedulePath(options);
  const config = readJson(filePath, {});

  if (!subcommand || options.help || subcommand === "--help" || subcommand === "-h") {
    scheduleUsage();
    return;
  }

  if (subcommand === "list") {
    const requestedSlug = positionals[0] ? normalizeSlug(positionals[0]) : "";
    listSchedules(config, requestedSlug);
    return;
  }

  const slug = normalizeSlug(positionals[0] || "");
  const target = normalizeTarget(positionals[1] || "");
  validateSlug(slug);

  if (!target) {
    throw new Error("Target is required.");
  }

  if (subcommand === "default") {
    if (!Array.isArray(config[slug]?.rules) || config[slug].rules.length === 0) {
      throw new Error(`Schedule for ${slug} must have at least one rule before setting a default target.`);
    }

    const schedule = ensureSchedule(config, slug, options.timezone || "UTC");
    schedule.default = target;
    if (options.timezone) schedule.timezone = options.timezone;
    saveScheduleConfig(filePath, config, options.dryRun, slug);
    return;
  }

  if (subcommand === "add") {
    if (!options.label) throw new Error("--label is required");

    const timezone = options.timezone || "UTC";
    const schedule = ensureSchedule(config, slug, timezone);
    if (options.timezone) schedule.timezone = timezone;

    const rule = {
      label: options.label,
      timezone,
      days: normalizeDays(options.days),
      from: validateTime(options.from, "--from"),
      to: validateTime(options.to, "--to"),
      target
    };

    const existingIndex = schedule.rules.findIndex((item) => item.label === rule.label);
    if (existingIndex >= 0) {
      schedule.rules[existingIndex] = {
        ...schedule.rules[existingIndex],
        ...rule
      };
    } else {
      schedule.rules.push(rule);
    }

    if (options.default) {
      schedule.default = normalizeTarget(options.default);
    }

    saveScheduleConfig(filePath, config, options.dryRun, slug);
    return;
  }

  throw new Error(`Unknown schedule command: ${subcommand}`);
}

function printLinkSummary(label, line) {
  const entry = parseLinkFields(line);
  console.log(label);
  printTable([[
    entry.slug,
    entry.state || "permanent",
    entry.owner || "",
    entry.title || "",
    entry.target || ""
  ]], ["Slug", "State", "Owner", "Title", "Target"]);
}

async function shouldReplaceSlug(existingLine, newLine, options) {
  printLinkSummary("Existing entry:", existingLine);
  printLinkSummary("New entry:", newLine);

  if (options.replace === true) return true;
  if (options.replace === false) return false;

  if (!process.stdin.isTTY) {
    throw new Error("Slug already exists. Rerun with --replace to update it or --no-replace to leave it unchanged.");
  }

  const rl = readline.createInterface({ input, output });
  try {
    const answer = (await rl.question("Replace the existing entry? (y/N): ")).trim().toLowerCase();
    return ["y", "yes", "true", "1"].includes(answer);
  } finally {
    rl.close();
  }
}

async function main() {
  const argv = process.argv.slice(2);

  if (argv[0] === "version" || argv[0] === "--version" || argv[0] === "-v") {
    console.log(VERSION);
    return;
  }

  if (argv[0] === "block") {
    run(process.execPath, ["scripts/blocklist-cli.mjs", ...argv.slice(1)]);
    return;
  }

  if (argv[0] === "schedule") {
    handleSchedule(argv.slice(1));
    return;
  }

  if (argv[0] === "tag" || argv[0] === "tags") {
    handleTags(argv.slice(1));
    return;
  }

  const { options, positionals } = parseArgs(argv);

  if (options.help) {
    usage();
    return;
  }

  if (positionals[0] === "list") {
    const listTarget = positionals[1] || "";
    if (["policy", "policies", "categories", "domain", "domains", "keyword", "keywords"].includes(listTarget)) {
      run(process.execPath, ["scripts/blocklist-cli.mjs", "list", ...positionals.slice(1), "--format", options.format]);
      return;
    }

    listLinks(listTarget, options);
    return;
  }

  const target = positionals[0] || "";
  let slug = positionals[1] || "";

  if (!target) {
    usage();
    process.exit(1);
  }

  if (!slug) {
    slug = randomSlug(configuredRandomSlugLength(options), configuredRandomSlugAlphabet());
  }

  if (options.state === "hidden") {
    throw new Error("State 'hidden' is deprecated. Use 'deactivated'.");
  }

  if (!VALID_STATES.has(options.state)) {
    throw new Error(`Invalid state: ${options.state}`);
  }

  slug = normalizeSlug(slug);
  validateSlug(slug);

  if (options.splat) {
    if (!target.includes(":splat")) {
      throw new Error("Splat target must include :splat");
    }
    slug = `${slug.replace(/\/+$/, "")}/*`;
  }

  const fields = [
    slug,
    target,
    options.state,
    options.title,
    options.description,
    options.tags,
    options.owner,
    options.expiresAt,
    options.notes
  ];
  assertNoPipe(fields);

  const line = fields.join("|");

  if (process.env.DRY_RUN === "true") {
    console.log(line);
    return;
  }

  const existingEntry = findSlugEntry(LINKS_FILE, slug);
  if (existingEntry) {
    const shouldReplace = await shouldReplaceSlug(existingEntry.line, line, options);
    if (!shouldReplace) {
      console.log("No changes made.");
      return;
    }

    replaceLine(LINKS_FILE, existingEntry.index, line);
    finalizeChange(LINKS_FILE, `feat(links): update ${slug}`);
    return;
  }

  appendLine(LINKS_FILE, line);

  finalizeChange(LINKS_FILE, `feat(links): add ${slug}`);
}

function finalizeChange(filePath, message) {
  run("npm", ["run", "check"]);
  run("git", ["add", filePath]);
  run("git", ["commit", "-m", message]);
  run("git", ["push"]);
}

main().catch((error) => {
  console.error(error instanceof Error ? error.message : String(error));
  process.exit(1);
});
