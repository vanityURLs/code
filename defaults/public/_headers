/*
  X-Generated-By: vanityURLs.link
  X-Robots-Tag: noindex, nofollow
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'

/
  Cache-Control: no-store

/index.html
  Cache-Control: no-store

/style.css
  Cache-Control: no-store

/llms.txt
  Cache-Control: no-store
  Content-Type: text/markdown; charset=utf-8

/llms-full.txt
  Cache-Control: no-store
  Content-Type: text/markdown; charset=utf-8

/lookup/*
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow

/*/_stats/*
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow
  X-Content-Type-Options: nosniff

/*/_stats/api/*
  Cache-Control: no-store
  Content-Type: application/json

/v8s.json
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow

/v8s-blocklist.json
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow

/v8s-site-config.json
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow
